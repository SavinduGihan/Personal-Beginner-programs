questions = [
    {"q": "What is the capital of Sri Lanka?", "a": "sri jayawardenepura kotte"},
    {"q": "What language are we learning?", "a": "python"},
    {"q": "What is 5 + 7?", "a": "12"}
]

score = 0

for item in questions:
    answer = input(item["q"] + " ").lower()

    if answer == item["a"]:
        print("Correct!")
        score += 1
    else:
        print("Wrong!")

print("Final Score:", score, "/", len(questions))